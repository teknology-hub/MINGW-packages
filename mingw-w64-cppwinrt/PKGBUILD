# Maintainer: Nuclearist <nuclearist@teknology-hub.com>
# Upstream maintainer: Biswapriyo Nath <nathbappai@gmail.com>

_realname=cppwinrt
pkgbase="mingw-w64-${_realname}"
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgdesc="C++ language projection for Windows Runtime (WinRT) APIs (mingw-w64)"
pkgver=2.0.250303.1
pkgrel=2
_windows_rs_ver=73
arch=("x86_64")
mingw_arch=("tek-x86_64")
url="https://aka.ms/cppwinrt"
msys2_repository_url="https://github.com/microsoft/cppwinrt"
license=("spdx:MIT")
depends=("${MINGW_PACKAGE_PREFIX}-cc-libs")
makedepends=(
  "${MINGW_PACKAGE_PREFIX}-cc"
  "${MINGW_PACKAGE_PREFIX}-cmake"
)
source=(
  "https://github.com/microsoft/cppwinrt/archive/${pkgver}/${_realname}-${pkgver}.tar.gz"
  "https://github.com/microsoft/windows-rs/archive/${_windows_rs_ver}/windows-rs-${_windows_rs_ver}.tar.gz"
)
sha256sums=(
  "da75b7047f4615a3db582ed8c75ee327f228b05bb47750621593594d2d0459e1"
  "cfcba6fce91907a4fbcfb009f606e0c6868ab8f88816b40c1d5f182e8b269493"
)

build() {
  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
  "${MINGW_PREFIX}/bin/cmake" \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX="${MINGW_PREFIX}" \
    -DCMAKE_INTERPROCEDURAL_OPTIMIZATION=ON \
    -DBUILD_TESTING=OFF \
    -DCPPWINRT_BUILD_VERSION="${pkgver}" \
    -S "${srcdir}/${_realname}-${pkgver}" \
    -B "${srcdir}/build-${MSYSTEM}"
  "${MINGW_PREFIX}/bin/cmake" --build "${srcdir}/build-${MSYSTEM}"
}

package() {
  install -Dm755 "${srcdir}/build-${MSYSTEM}/cppwinrt.exe" "${pkgdir}${MINGW_PREFIX}/bin/cppwinrt.exe"
  "${srcdir}/build-${MSYSTEM}/cppwinrt.exe" \
    -input "${srcdir}/windows-rs-${_windows_rs_ver}/crates/libs/bindgen/default" \
    -output "${pkgdir}${MINGW_PREFIX}/include"
}
