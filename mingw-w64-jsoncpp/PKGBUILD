# Maintainer: Nuclearist <nuclearist@teknology-hub.com>
# Upstream maintainer: Drew Waranis <drew@waran.is>

_realname="jsoncpp"
pkgbase="mingw-w64-${_realname}"
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgdesc="A C++ library for interacting with JSON (mingw-w64)"
pkgver=1.9.7
pkgrel=1
arch=("x86_64")
mingw_arch=("tek-x86_64")
url="https://github.com/open-source-parsers/jsoncpp"
msys2_references=("cpe: cpe:2.3:a:jsoncpp_project:jsoncpp")
msys2_repository_url="https://github.com/open-source-parsers/jsoncpp"
license=("spdx:MIT")
depends=("${MINGW_PACKAGE_PREFIX}-cc-libs")
makedepends=(
  "${MINGW_PACKAGE_PREFIX}-cc"
  "${MINGW_PACKAGE_PREFIX}-cmake"
)
source=("https://github.com/open-source-parsers/jsoncpp/archive/${pkgver}/${_realname}-${pkgver}.tar.gz")
sha256sums=("830bf352d822d8558e9d0eb19d640d2e38536b4b6699c30a4488da09d5b1df18")

build() {
  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
  "${MINGW_PREFIX}/bin/cmake" \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_DLL_NAME_WITH_SOVERSION=ON \
    -DCMAKE_INSTALL_PREFIX=${MINGW_PREFIX} \
    -DCMAKE_INTERPROCEDURAL_OPTIMIZATION=ON \
    -DBUILD_OBJECT_LIBS=OFF \
    -DJSONCPP_WITH_TESTS=OFF \
    -S "${srcdir}/${_realname}-${pkgver}" \
    -B "${srcdir}/build-${MSYSTEM}"
  "${MINGW_PREFIX}/bin/cmake" --build "${srcdir}/build-${MSYSTEM}"
}

package() {
  DESTDIR="${pkgdir}" "${MINGW_PREFIX}/bin/cmake" --install "${srcdir}/build-${MSYSTEM}"
}
