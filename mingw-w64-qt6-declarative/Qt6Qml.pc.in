prefix=MINGW_PREFIX
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/share/qt6/bin
libdir=${prefix}/lib
includedir=${prefix}/include/qt6

Name: Qt6 Qml
Description: Qt Qml module
Version: PKGVER
Requires: Qt6Core Qt6QmlIntegration
Libs: -L${libdir} -lQt6Qml
Libs.private: -L${prefix}/share/qt6/qml/QtQml -lqmlplugin
Cflags: -I${includedir}/QtQml -I${includedir} -DQT_QML_LIB
