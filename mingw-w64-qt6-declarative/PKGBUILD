build() {
  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
  "${MINGW_PREFIX}/bin/cmake" \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX="${MINGW_PREFIX}" \
    -DCMAKE_INTERPROCEDURAL_OPTIMIZATION=ON \
    -DPython_EXECUTABLE="${MINGW_PREFIX}/bin/python" \
    -DBUILD_SHARED_LIBS=OFF \
    -DQT_GENERATE_SBOM=OFF \
    -DFEATURE_qml_profiler=OFF \
    -DFEATURE_quick_designer=OFF \
    -S "${srcdir}/${_pkgfn}" \
    -B "${srcdir}/build-${MSYSTEM}"
  "${MINGW_PREFIX}/bin/cmake" --build "${srcdir}/build-${MSYSTEM}"
}

package() {
  DESTDIR="${pkgdir}" "${MINGW_PREFIX}/bin/cmake" --install "${srcdir}/build-${MSYSTEM}"
  local PREFIX_WIN="$(cygpath -m "${MINGW_PREFIX}")"
  find "${pkgdir}${MINGW_PREFIX}/lib/cmake" -type f \( -name '*.cmake' \) \
      -exec sed -i -e "s|${PREFIX_WIN}|${MINGW_PREFIX}|g" {} \;
  find "${pkgdir}${MINGW_PREFIX}/share/qt6" -type f \( -name '*.pri' \) \
      -exec sed -i -e "s|${PREFIX_WIN}|${MINGW_PREFIX}|g" {} \;
  mkdir -p "${pkgdir}${MINGW_PREFIX}/lib/pkgconfig"
  # Create .pc files manually because the project doesn't produce them for
  # static builds, and meson's qmake-based discovery method doesn't link
  # transitive dependencies
  for module in Qml QmlCompiler QmlCore QmlIntegration QmlLocalStorage QmlMeta \
    QmlModels QmlWorkerScript QmlXmlListModel Quick QuickControls2 \
    QuickControls2Basic QuickControls2BasicStyleImpl \
    QuickControls2FluentWinUI3StyleImpl QuickControls2Fusion \
    QuickControls2FusionStyleImpl QuickControls2Imagine \
    QuickControls2ImagineStyleImpl QuickControls2Impl QuickControls2Material \
    QuickControls2MaterialStyleImpl QuickControls2Universal \
    QuickControls2UniversalStyleImpl QuickDialogs2 QuickDialogs2QuickImpl \
    QuickDialogs2Utils QuickEffects QuickLayouts QuickTemplates2 \
    QuickVectorImage QuickVectorImageHelpers
  do
    sed "s|MINGW_PREFIX|${MINGW_PREFIX}|;s|PKGVER|${pkgver}|" "${srcdir}/Qt6${module}.pc.in" > "${pkgdir}${MINGW_PREFIX}/lib/pkgconfig/Qt6${module}.pc"
  done
}
