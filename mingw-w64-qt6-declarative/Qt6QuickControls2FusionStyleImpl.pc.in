prefix=MINGW_PREFIX
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/share/qt6/bin
libdir=${prefix}/lib
includedir=${prefix}/include/qt6

Name: Qt6 QuickControls2FusionStyleImpl
Description: Qt QuickControls2FusionStyleImpl module
Version: PKGVER
Libs: -L${libdir} -lQt6QuickControls2FusionStyleImpl
Libs.private: -L${prefix}/share/qt6/qml/QtQuick/Controls/Fusion/impl -lqtquickcontrols2fusionstyleimplplugin
Cflags: -I${includedir}/QtQuickControls2FusionStyleImpl -I${includedir} -DQT_QUICKCONTROLS2FUSIONSTYLEIMPL_LIB
