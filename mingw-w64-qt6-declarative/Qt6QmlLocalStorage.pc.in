prefix=MINGW_PREFIX
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/share/qt6/bin
libdir=${prefix}/lib
includedir=${prefix}/include/qt6

Name: Qt6 QmlLocalStorage
Description: Qt QmlLocalStorage module
Version: PKGVER
Requires: Qt6Sql
Libs: -L${libdir} -lQt6QmlLocalStorage
Cflags: -I${includedir}/QtQmlLocalStorage -I${includedir} -DQT_QMLLOCALSTORAGE_LIB
