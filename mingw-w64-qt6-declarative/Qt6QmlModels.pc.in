prefix=MINGW_PREFIX
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/share/qt6/bin
libdir=${prefix}/lib
includedir=${prefix}/include/qt6

Name: Qt6 QmlModels
Description: Qt QmlModels module
Version: PKGVER
Requires: Qt6Core Qt6Qml
Libs: -L${libdir} -lQt6QmlModels
Libs.private: -L${prefix}/share/qt6/qml/QtQml/Models -lmodelsplugin
Cflags: -I${includedir}/QtQmlModels -I${includedir} -DQT_QMLMODELS_LIB
