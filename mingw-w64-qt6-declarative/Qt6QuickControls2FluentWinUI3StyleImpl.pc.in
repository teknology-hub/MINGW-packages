prefix=MINGW_PREFIX
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/share/qt6/bin
libdir=${prefix}/lib
includedir=${prefix}/include/qt6

Name: Qt6 QuickControls2FluentWinUI3StyleImpl
Description: Qt QuickControls2FluentWinUI3StyleImpl module
Version: PKGVER
Libs: -L${libdir} -lQt6QuickControls2FluentWinUI3StyleImpl
Libs.private: -L${prefix}/share/qt6/qml/QtQuick/Controls/FluentWinUI3/impl -lqtquickcontrols2fluentwinui3styleimplplugin
Cflags: -I${includedir}/QtQuickControls2FluentWinUI3StyleImpl -I${includedir} -DQT_QUICKCONTROLS2FLUENTWINUI3STYLEIMPL_LIB
