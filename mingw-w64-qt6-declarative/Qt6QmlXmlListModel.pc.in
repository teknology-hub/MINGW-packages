prefix=MINGW_PREFIX
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/share/qt6/bin
libdir=${prefix}/lib
includedir=${prefix}/include/qt6

Name: Qt6 QmlXmlListModel
Description: Qt QmlXmlListModel module
Version: PKGVER
Requires: Qt6Core Qt6Qml
Libs: -L${libdir} -lQt6QmlXmlListModel
Libs.private: -L${prefix}/share/qt6/qml/QtQml/XmlListModel -lqmlxmllistmodelplugin
Cflags: -I${includedir}/QtQmlXmlListModel -I${includedir} -DQT_QMLXMLLISTMODEL_LIB
