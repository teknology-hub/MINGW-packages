prefix=MINGW_PREFIX
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/share/qt6/bin
libdir=${prefix}/lib
includedir=${prefix}/include/qt6

Name: Qt6 QuickControls2Material
Description: Qt QuickControls2Material module
Version: PKGVER
Requires.private: Qt6QuickControls2MaterialStyleImpl
Libs: -L${libdir} -lQt6QuickControls2Material
Libs.private: -L${prefix}/share/qt6/qml/QtQuick/Controls/Material -lqtquickcontrols2materialstyleplugin
Cflags: -I${includedir}/QtQuickControls2Material -I${includedir} -DQT_QUICKCONTROLS2MATERIAL_LIB
