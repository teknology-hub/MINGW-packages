prefix=MINGW_PREFIX
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/share/qt6/bin
libdir=${prefix}/lib
includedir=${prefix}/include/qt6

Name: Qt6 QuickControls2BasicStyleImpl
Description: Qt QuickControls2BasicStyleImpl module
Version: PKGVER
Libs: -L${libdir} -lQt6QuickControls2BasicStyleImpl
Libs.private: -L${prefix}/share/qt6/qml/QtQuick/Controls/Basic/impl -lqtquickcontrols2basicstyleimplplugin
Cflags: -I${includedir}/QtQuickControls2BasicStyleImpl -I${includedir} -DQT_QUICKCONTROLS2BASICSTYLEIMPL_LIB
