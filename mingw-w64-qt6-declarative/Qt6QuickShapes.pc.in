prefix=MINGW_PREFIX
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/share/qt6/bin
libdir=${prefix}/lib
includedir=${prefix}/include/qt6

Name: Qt6 QuickShapes
Description: Qt QuickShapes module
Version: PKGVER
Requires: Qt6Core Qt6Qml
Libs: -L${libdir} -lQt6QuickShapes
Libs.private: -L${prefix}/share/qt6/qml/QtQuick/Shapes -lqmlshapesplugin
Cflags: -I${includedir}/QtQuickShapes -I${includedir} -DQT_QUICKSHAPES_LIB

