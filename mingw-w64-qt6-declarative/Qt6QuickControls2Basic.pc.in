prefix=MINGW_PREFIX
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/share/qt6/bin
libdir=${prefix}/lib
includedir=${prefix}/include/qt6

Name: Qt6 QuickControls2Basic
Description: Qt QuickControls2Basic module
Version: PKGVER
Requires.private: Qt6QuickControls2BasicStyleImpl
Libs: -L${libdir} -lQt6QuickControls2Basic
Libs.private: -L${prefix}/share/qt6/qml/QtQuick/Controls/Basic -lqtquickcontrols2basicstyleplugin
Cflags: -I${includedir}/QtQuickControls2Basic -I${includedir} -DQT_QUICKCONTROLS2BASIC_LIB
