prefix=MINGW_PREFIX
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/share/qt6/bin
libdir=${prefix}/lib
includedir=${prefix}/include/qt6

Name: Qt6 QuickControls2
Description: Qt QuickControls2 module
Version: PKGVER
Requires: Qt6Core Qt6Gui Qt6Quick Qt6QuickShapes
Requires.private: Qt6QuickControls2FluentWinUI3StyleImpl Qt6QuickControls2Impl Qt6QuickControls2Fusion Qt6QuickTemplates2
Libs: -L${libdir} -lQt6QuickControls2
Libs.private: -L${prefix}/share/qt6/qml/QtQuick/Controls -lqtquickcontrols2plugin -L${prefix}/share/qt6/qml/QtQuick/Controls/FluentWinUI3 -lqtquickcontrols2fluentwinui3styleplugin -L${prefix}/share/qt6/qml/QtQuick/Controls/Windows -lqtquickcontrols2windowsstyleplugin
Cflags: -I${includedir}/QtQuickControls2 -I${includedir} -DQT_QUICKCONTROLS2_LIB
