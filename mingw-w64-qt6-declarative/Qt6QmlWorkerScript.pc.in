prefix=MINGW_PREFIX
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/share/qt6/bin
libdir=${prefix}/lib
includedir=${prefix}/include/qt6

Name: Qt6 QmlWorkerScript
Description: Qt QmlWorkerScript module
Version: PKGVER
Requires: Qt6Core Qt6Qml
Libs: -L${libdir} -lQt6QmlWorkerScript
Libs.private: -L${prefix}/share/qt6/qml/QtQml/WorkerScript -lworkerscriptplugin
Cflags: -I${includedir}/QtQmlWorkerScript -I${includedir} -DQT_QMLWORKERSCRIPT_LIB
