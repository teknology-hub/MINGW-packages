prefix=MINGW_PREFIX
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/share/qt6/bin
libdir=${prefix}/lib
includedir=${prefix}/include/qt6

Name: Qt6 Quick
Description: Qt Quick module
Version: PKGVER
Requires: Qt6Core Qt6Gui Qt6Qml
Requires.private: Qt6QmlMeta Qt6QmlModels
Libs: -L${libdir} -lQt6Quick
Libs.private: -L${libdir} -lQt6QmlLocalStorage -L${prefix}/share/qt6/qml/QtQuick -lqtquick2plugin -L${prefix}/share/qt6/qml/QtQuick/LocalStorage -lqmllocalstorageplugin -L${prefix}/share/qt6/qml/QtQuick/NativeStyle -lqtquickcontrols2nativestyleplugin -L${prefix}/share/qt6/qml/QtQuick/Particles -lparticlesplugin -L${prefix}/share/qt6/qml/QtQuick/Window -lquickwindowplugin
Cflags: -I${includedir}/QtQuick -I${includedir} -DQT_QUICK_LIB
