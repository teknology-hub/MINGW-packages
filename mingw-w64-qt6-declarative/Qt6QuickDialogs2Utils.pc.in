prefix=MINGW_PREFIX
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/share/qt6/bin
libdir=${prefix}/lib
includedir=${prefix}/include/qt6

Name: Qt6 QuickDialogs2Utils
Description: Qt QuickDialogs2Utils module
Version: PKGVER
Requires: Qt6Core
Libs: -L${libdir} -lQt6QuickDialogs2Utils
Cflags: -I${includedir}/QtQuickDialogs2Utils -I${includedir} -DQT_QUICKDIALOGS2UTILS_LIB
