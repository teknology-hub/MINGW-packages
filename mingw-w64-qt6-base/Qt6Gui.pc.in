prefix=MINGW_PREFIX
libdir=${prefix}/lib
includedir=${prefix}/include/qt6

Name: Qt6 Gui
Description: Qt Gui module
Version: PKGVER
Requires: Qt6Core
Requires.private: libjpeg,libpng,zlib
Libs: -L${libdir} -lQt6Gui
Libs.private: -ld3d11 -ld3d12 -ldwmapi -ldwrite -ldxgi -limm32 -lsetupapi -lshcore -lshlwapi -luxtheme -lwtsapi32 -L${prefix}/share/qt6/plugins/iconengines -lqsvgicon -L${prefix}/share/qt6/plugins/imageformats -lqgif -lqico -lqjpeg -L${prefix}/share/qt6/plugins/platforms -lqwindows
Cflags: -I${includedir}/QtGui -I${includedir} -DQT_GUI_LIB
