prefix=MINGW_PREFIX
libdir=${prefix}/lib
includedir=${prefix}/include/qt6

Name: Qt6 Sql
Description: Qt Sql module
Version: PKGVER
Requires: Qt6Core
Libs: -L${libdir} -lQt6Sql
Libs.private: -L${prefix}/share/qt6/plugins/sqldrivers -lqsqlite
Cflags: -I${includedir}/QtSql -I${includedir} -DQT_SQL_LIB
