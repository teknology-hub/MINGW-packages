prepare() {
  cd "${srcdir}/${_pkgfn}"
  patch -Np1 -i "${srcdir}/003-adjust-qmake-conf-mingw.patch"
  patch -Np1 -i "${srcdir}/004-qt-6.2.0-win32-g-Add-QMAKE_EXTENSION_IMPORTLIB-defaulting-to-.patch"
  patch -Np1 -i "${srcdir}/006-qt-6.2.0-dont-add-resource-files-to-qmake-libs.patch"
  patch -Np1 -i "${srcdir}/009-qfileinfo-undefine-mingw-stat.patch"
}

build() {
  PKG_CONFIG_ARGN="--static" \
  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
  "${MINGW_PREFIX}/bin/cmake" \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX="${MINGW_PREFIX}" \
    -DCMAKE_INTERPROCEDURAL_OPTIMIZATION=ON \
    -DBUILD_SHARED_LIBS=OFF \
    -DQT_GENERATE_SBOM=OFF \
    -DQT_QMAKE_TARGET_MKSPEC=win32-clang-g++ \
    -DINSTALL_ARCHDATADIR=share/qt6 \
    -DINSTALL_DATADIR=share/qt6 \
    -DINSTALL_DESCRIPTIONSDIR=share/qt6/modules \
    -DINSTALL_INCLUDEDIR=include/qt6 \
    -DINSTALL_MKSPECSDIR=share/qt6/mkspecs \
    -DFEATURE_androiddeployqt=OFF \
    -DFEATURE_cpp_winrt=ON \
    -DFEATURE_cssparser=OFF \
    -DFEATURE_cxx20=ON \
    -DFEATURE_dbus=OFF \
    -DFEATURE_freetype=OFF \
    -DFEATURE_harfbuzz=OFF \
    -DFEATURE_network=OFF \
    -DFEATURE_openssl_hash=ON \
    -DFEATURE_pkg_config=ON \
    -DFEATURE_printsupport=OFF \
    -DFEATURE_relocatable=ON \
    -DFEATURE_sql_odbc=OFF \
    -DFEATURE_sql_sqlite=ON \
    -DFEATURE_system_sqlite=ON \
    -DFEATURE_testlib=OFF \
    -DFEATURE_texthtmlparser=OFF \
    -DFEATURE_textmarkdownreader=OFF \
    -DFEATURE_textmarkdownwriter=OFF \
    -DFEATURE_textodfwriter=OFF \
    -DFEATURE_widgets=OFF \
    -DFEATURE_windeployqt=OFF \
    -DFEATURE_windows_ioring=ON \
    -DINPUT_freetype=no \
    -DINPUT_harfbuzz=no \
    -DINPUT_libjpeg=system \
    -DINPUT_libmd4c=no \
    -DINPUT_libpng=system \
    -DINPUT_opengl=no \
    -DINPUT_openssl=linked \
    -DPCRE2_USE_STATIC_LIBS=ON \
    -S "${srcdir}/${_pkgfn}" \
    -B "${srcdir}/build-${MSYSTEM}"
  PATH="${srcdir}/build-${MSYSTEM}/bin:${PATH}" \
  "${MINGW_PREFIX}/bin/cmake" --build "${srcdir}/build-${MSYSTEM}"
}

package() {
  DESTDIR="${pkgdir}" "${MINGW_PREFIX}/bin/cmake" --install "${srcdir}/build-${MSYSTEM}"
  rm -r "${pkgdir}${MINGW_PREFIX}/share/qt6/doc"
  local PREFIX_WIN="$(cygpath -m "${MINGW_PREFIX}")"
  find "${pkgdir}${MINGW_PREFIX}/bin" -type f \( -name '*.bat' \) \
      -exec sed -i -e "s|${PREFIX_WIN}|${MINGW_PREFIX}|g" {} \;
  find "${pkgdir}${MINGW_PREFIX}/lib/cmake" -type f \( -name '*.cmake' \) \
      -exec sed -i -e "s|${PREFIX_WIN}|${MINGW_PREFIX}|g" {} \;
  find "${pkgdir}${MINGW_PREFIX}/share/qt6" -type f \( -name '*.pri' -o -name '*.bat' \) \
      -exec sed -i -e "s|${PREFIX_WIN}|${MINGW_PREFIX}|g" {} \;
  mkdir -p "${pkgdir}${MINGW_PREFIX}/lib/pkgconfig"
  # Create .pc files manually because the project doesn't produce them for
  # static builds, and meson's qmake-based discovery method doesn't link
  # transitive dependencies
  for module in Concurrent Core Gui Sql Xml
  do
    sed "s|MINGW_PREFIX|${MINGW_PREFIX}|;s|PKGVER|${pkgver}|" "${srcdir}/Qt6${module}.pc.in" > "${pkgdir}${MINGW_PREFIX}/lib/pkgconfig/Qt6${module}.pc"
  done
}
